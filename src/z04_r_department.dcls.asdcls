@EndUserText.label: 'Abteilung Zugriffssteuerung Ü 17'
@MappingRole: true
define role Z04_R_DEPARTMENT {
    grant 
        select
            on
                Z04_R_DEPARTMENT
                    where
                        (Id) = aspect pfcg_auth(Z04DPMENT, Z04DPMT, ACTVT = '03');
                        
}